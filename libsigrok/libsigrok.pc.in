prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: libsigrok
Description: Backend library for sigrok signal analysis (CH32h417-only build)
URL: http://www.sigrok.org
Version: 0.6.0-ch32h417
Requires: glib-2.0
Requires.private: libusb-1.0
Libs: -L${libdir} -lsigrok
Libs.private: -lm
Cflags: -I${includedir}
